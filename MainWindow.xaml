<Window x:Class="CyberSecurityChatbot2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Assistant"
        Height="750"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#ECEFF4">

    <Grid>

        <Border Margin="20"
                CornerRadius="25"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="85"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0"
                        Background="#1A365D"
                        CornerRadius="25,25,0,0">

                    <Grid Margin="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LOGO -->
                        <Border Width="55"
                                Height="55"
                                CornerRadius="30"
                                Background="White"
                                VerticalAlignment="Center">

                            <Image Source="Assets/botavatar.png"
                                   Stretch="Uniform"/>
                        </Border>

                        <!-- BOT INFO -->
                        <StackPanel Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalAlignment="Center">

                            <TextBlock Text="Cybersecurity Assistant"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="DarkGray"/>

                            <TextBlock Text="🟢 Online | Ready to Help"
                                       FontSize="13"
                                       Foreground="HotPink"/>
                        </StackPanel>

                    </Grid>
                </Border>

                <!-- CHAT AREA -->
                <Border Grid.Row="1"
                        Margin="15"
                        Background="DarkGray"
                        CornerRadius="20">

                    <TextBox x:Name="txtChat"
                             Margin="20"
                             FontSize="15"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- MESSAGE BAR -->
                <Border Grid.Row="2"
                        Background="DarkSlateBlue"
                        CornerRadius="0,0,25,25">

                    <Grid Margin="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtMessage"
                                 Height="50"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>

                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Content="Send"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="White"
                                Background="#2563EB"
                                Click="Button_Click"/>
                    </Grid>

                </Border>

            </Grid>

        </Border>

    </Grid>
</Window>